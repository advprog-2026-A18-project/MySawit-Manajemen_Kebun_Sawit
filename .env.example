# Copy to .env and fill values for local development or Neon

# Local Postgres (docker-compose)
# Uncomment if using local postgres container
# DATABASE_URL=jdbc:postgresql://localhost:5432/neondb?user=neondb_owner&password=password&sslmode=disable

# Neon JDBC example (Java driver format)
# Get this from Neon Console -> Connect -> Java
# DATABASE_URL=jdbc:postgresql://ep-XXXXX-pooler.us-east-2.aws.neon.tech/neondb?user=neondb_owner&password=YOUR_PASSWORD&sslmode=require&channelBinding=require

# For GitHub Actions / CI, secrets should be set in repository settings
